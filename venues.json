{
  "melbourne": [
    {
      "name": "The Corner Hotel",
      "url": "https://www.cornerhotel.com/events-and-specials/",
      "type": "corner",
      "selectors": {
        "container": ".calendar__item",
        "title": ".calendar__item-title",
        "date": ".calendar__item-date"
      },
      "exclude_patterns": [
        "saturdays?\\s+at\\s+(the\\s+)?corner",
        "fridays?\\s+at\\s+(the\\s+)?corner"
      ]
    },
    {
      "name": "The Tote",
      "url": "https://thetotehotel.com/",
      "type": "js",
      "selectors": {
        "container": "[class*=\"event\"]",
        "title": ".event-name, .event-details",
        "date": ".event-date, .highlight"
      },
      "note": "Uses JavaScript - uses Playwright"
    },
    {
      "name": "Max Watts",
      "url": "https://www.maxwatts.com.au/",
      "type": "js",
      "timeout": 180000,
      "wait_time": 60000,
      "selectors": {
        "container": ".event-details",
        "title": ".event-details",
        "date": "[class*='date']"
      },
      "note": "Uses Playwright - needs longer timeout"
    },
    {
      "name": "Shotkickers",
      "url": "https://www.shotkickers.com/gigs",
      "type": "js",
      "selectors": {
        "container": ".event-tile",
        "title": ".event-name",
        "date": ".date-time-venue"
      },
      "note": "Algolia/Oztix site - Thornbury (updated 2026-07-10)"
    },
    {
      "name": "Bendigo Hotel",
      "url": "https://www.bendigohotel.com.au/gigs",
      "type": "js",
      "selectors": {
        "container": "article.hit",
        "title": ".event-name",
        "date": ".floating-date-time"
      },
      "note": "Squarespace/Oztix site - Collingwood"
    },
    {
      "name": "Night Hawks",
      "url": "https://nighthawksbar.com.au/allgigs",
      "type": "js",
      "selectors": {
        "container": ".eventlist-event:not(.eventlist-event--past)",
        "title": ".eventlist-title",
        "date": ".eventlist-datetag"
      },
      "note": "Squarespace site"
    },
    {
      "name": "Cherry Bar",
      "url": "https://www.cherrybar.com.au/events/",
      "selectors": {
        "container": ".card-body",
        "title": "h4",
        "date": "p.font-13 span"
      },
      "note": "Static site - Melbourne CBD"
    },
    {
      "name": "The Old Bar",
      "url": "https://www.theoldbar.com.au/",
      "type": "js",
      "selectors": {
        "container": ".eventlist-event:not(.eventlist-event--past)",
        "title": ".eventlist-description strong",
        "date": ".eventlist-datetag"
      },
      "note": "Squarespace site - Fitzroy"
    },
    {
      "name": "The Evelyn Hotel",
      "url": "https://evelynhotel.com.au/events",
      "selectors": {
        "container": "a.eventLink",
        "title": "h2.eventTitle",
        "date": "h2.date"
      },
      "exclude_patterns": [
        "wine\\s+tasting",
        "free\\s+wine",
        "ev\\s+market",
        "standing\\s+circle"
      ],
      "note": "Static site - Fitzroy, Oztix venue"
    },
    {
      "name": "Kindred Studios",
      "url": "https://kindredstudios.com.au/whats-on/",
      "type": "js",
      "selectors": {
        "container": ".event-tile",
        "title": ".event-name",
        "date": ".date-container"
      },
      "exclude_patterns": [
        "video\\s+bingo",
        "trivia",
        "open\\s+mic"
      ],
      "note": "Algolia/Oztix site - Footscray"
    },
    {
      "name": "The Croxton Bandroom",
      "url": "http://thecroxton.com.au",
      "type": "js",
      "selectors": {
        "container": ".event-tile",
        "title": ".event-name",
        "date": ".date-container"
      },
      "note": "Algolia/Oztix site - Thornbury, HTTP only"
    }
  ],
  "geelong": [
    {
      "name": "Barwon Club",
      "url": "https://www.barwonclub.com.au/",
      "type": "js",
      "selectors": {
        "container": ".gig-card",
        "title": ".gig-title",
        "date": ".gig-date"
      },
      "note": "Uses JavaScript - uses Playwright"
    },
    {
      "name": "Barwon Heads Hotel",
      "url": "https://barwonheadshotel.com.au/gigs/",
      "type": "js",
      "selectors": {
        "container": ".gig",
        "title": "h3.gig__name",
        "date": "span.gig__date"
      },
      "note": "WordPress site - uses Playwright"
    }
  ],
  "surfcoast": [
    {
      "name": "Torquay Hotel",
      "url": "https://torquayhotel.com.au/gigs/",
      "type": "scrapeops",
      "selectors": {
        "container": ".gig",
        "title": ".gig__name",
        "date": ".gig__date"
      },
      "note": "Uses ScrapeOps"
    }
  ]
}
